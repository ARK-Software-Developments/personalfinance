@using PersonalFinance.Helper
@using PersonalFinance.Models.IngresosMensuales
@using System.Globalization
@using PersonalFinanceApiNetCoreModel
@{

    List<Prestamo> prestamos = ViewBag.Prestamos;
    List<PrestamoDetalle> prestamoDetalles = ViewBag.PrestamosDetalles;
    List<SelectListItem> lstEstados = ViewBag.Estados;
    List<SelectListItem> lstEntidades = ViewBag.Entidades;

}


<link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
<link rel="stylesheet" href="~/css/personalfinance.styles.css">

<script>
     $(function () {
        $('[data-bs-toggle="tooltip"]').tooltip();
    });

</script>

<div class="text-center">
    <h1 class="display-5">@ViewBag.Message</h1>
    <p>Listado de @ViewBag.Modulo.</p>
</div>

<div class="tab-content">
    <div class="row">
        <table align="left">
            <tr>
                <td scope="row" align="left">
                    <div class="datatable-search">
                        <form method="get">
                            @if (@ViewBag.Buscar == "Buscar")
                            {
                                <input type="text"
                                       name="search"
                                       value=""
                                       placeholder="Buscar..."
                                       class="form-control"
                                       style="width: 250px; display:inline-block;" />
                            }


                            <button type="submit" class="btn btn-primary">
                                @ViewBag.Buscar
                            </button>
                        </form>

                    </div>
                </td>
                <td scope="row" align="left">&nbsp;|&nbsp;</td>
                <td scope="row" align="left">
                    <div class="form-group">
                        <span class="form-label">Estados:</span>
                        <form method="get">
                            <select id="Estado" name="Estado" class="form-control" onchange="this.form.submit()" required>
                                @foreach (var item in @lstEstados)
                                {
                                    if (item.Selected)
                                    {
                                        <option value="@item.Value" selected>@item.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                        </form>
                    </div>
                </td>
                <td scope="row" align="left">&nbsp;|&nbsp;</td>
                <td scope="row" align="left">
                    <div class="form-group">
                        <span class="form-label">Entidades:</span>
                        <form method="get">
                            <select id="Entidad" name="Entidad" class="form-control" onchange="this.form.submit()" required>
                                @foreach (var item in @lstEntidades)
                                {
                                    if (item.Selected)
                                    {
                                        <option value="@item.Value" selected>@item.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                        </form>
                    </div>
                </td>
            </tr>
        </table>
    </div>
    <p></p>

    <div class="row">
        <table class="table myaccordion table-hover" id="accordion">
            <thead>
                <tr>
                    <th scope="col">Id</th>
                    <th scope="col">Número</th>
                    <th scope="col">Cód. Trans.</th>
                    <th scope="col">Beneficiario</th>
                    <th scope="col" align="center">Fecha de Depósito</th>
                    <th scope="col">Resumen</th>
                    <th scope="col">Rason</th>
                    <th scope="col">Entidad</th>
                    <th scope="col" style="text-align: right; padding-right: 5px;">Total Capital</th>
                    <th scope="col" style="text-align: right; padding-right: 5px;">Cuotas</th>
                    <th scope="col" style="text-align: right; padding-right: 5px;">Monto Cuota Prom.</th>
                    <th scope="col" style="text-align: right; padding-right: 5px;">Total Deuda</th>
                    <th scope="col">Estado</th>
                    <th scope="col">Cant. Cuotas</th>
                    <th>
                        &nbsp;
                        <form method="post" asp-controller="@ViewBag.Modulo">
                            <button type="submit" class="btn btn-primary" asp-controller="@ViewBag.Modulo" asp-action="@ViewBag.Modulo" name="action" value="openFormAdd">Add new @ViewBag.Modulo</button>
                        </form>
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entidad in @prestamos)
                {
                    string color = string.Empty;

                    if (entidad.Estado == "PAGO ATRAZADO")
                    {
                        color = "#ffd699";
                    }
                    else if (entidad.Estado == "PAGO AL DIA")
                    {
                        color = "#00bcd4";
                    }
                    else if (entidad.Estado == "SIN PROYECCION")
                    {
                        color = "#ff9800";
                    }
                    else if (entidad.Estado == "COMPLETADO")
                    {
                        color = "#dbefdc";
                    }
                    else if (entidad.Estado == "PERDIDO")
                    {
                        color = "#5b6b79";
                    }

                    <tr style="background-color: @color;">
                        <td scope="row" id="Id">@entidad.Id</td>
                        <td scope="row" id="Numero">@entidad.Numero</td>
                        <td scope="row" id="CodigoTransaccion">@entidad.CodigoTransaccion</td>
                        <td scope="row" id="Beneficiario">@entidad.Beneficiario</td>
                        <td scope="row" id="FechaDeposito">@entidad.FechaDeposito?.ToString("dd/MM/yyy", new CultureInfo("es-ES"))</td>
                        <td scope="row" id="Resumen">@entidad.Resumen</td>
                        <td scope="row" id="Razon">@entidad.Razon</td>
                        <td scope="row" id="NombreEntidad">@entidad.Entidad.Nombre</td>
                        <td scope="row" id="TotalCapital" style="padding-right: 20px; text-align: right;">@entidad.TotalCapital.ToString("C", new CultureInfo("es-AR"))</td>
                        <td scope="row" id="Cuotas" style="padding-right: 20px; text-align: right;">@entidad.Cuotas</td>
                        <td scope="row" id="MontoCuota" style="padding-right: 20px; text-align: right;">@entidad.MontoCuota.ToString("C", new CultureInfo("es-AR"))</td>
                        <td scope="row" id="TotalDeuda" style="padding-right: 20px; text-align: right;">@entidad.TotalDeuda.ToString("C", new CultureInfo("es-AR"))</td>
                        <td scope="row" id="Estado">@entidad.Estado</td>
                        <td scope="row" id="CantidadCuotas">@entidad.CantidadCuotas</td>
                        <td scope="row">
                            <form method="post" asp-controller="@ViewBag.Modulo" asp-route-id="@entidad.Id">
                                <input type="text" name="Id" value="@entidad.Id" hidden="hidden" />
                                <button type="submit" class="btn btn-secondary" asp-controller="@ViewBag.Modulo" asp-action="@ViewBag.Modulo" name="action" value="openFormEdit">Edit</button>
                                &nbsp;|&nbsp;
                                <button type="submit" class="btn btn-secondary" asp-controller="@ViewBag.Modulo" asp-action="@ViewBag.Modulo" name="action" value="openFormView">View</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<p></p>
<p>>>>>>&nbsp;&nbsp;@ViewBag.Ruta</p>
<a href="/@ViewBag.Modulo" class="btn btn-secondary">Volver</a>

<script src="~/js/jquery.min.js"></script>
<script src="~/js/popper.js"></script>
<script src="~/js/bootstrap.min.js"></script>
<script src="~/js/main.js"></script>