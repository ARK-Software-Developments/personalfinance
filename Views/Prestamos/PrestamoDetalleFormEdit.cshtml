@using PersonalFinance.Helper
@using PersonalFinance.Models.Entidades
@using PersonalFinance.Models.Gastos
@using System.Globalization
@using PersonalFinance.Models.IngresosTipo
@using PersonalFinanceApiNetCoreModel
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@


@{
    CultureInfo culturaArgentina = new CultureInfo("es-AR");
    PrestamoDetalle prestamoDetalle = ViewBag.PrestamoDetalle;   

    var lstEstados = new List<SelectListItem>();
    foreach (var e in ViewBag.Estados)
    {
        lstEstados.Add(
        new SelectListItem()
        {
            Value = e.Value.ToString(),
            Text = e.Text,
            Selected = (prestamoDetalle.Estado == e.Text ? true : false)
        });
    }


}

<link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
<link rel="stylesheet" href="~/css/personalfinance.styles.css">

<script>
    function CalcularMonto() {
                console.log($('#Cuotas :selected').val());

                var cuotas = parseFloat($('#Cuotas').val());
                var MontoCuotaPromedio = parseFloat($('#MontoCuotaPromedio').val());
                var montoTotal = MontoCuotaPromedio * cuotas;

                $('#MontoTotal').val(montoTotal);
            };

</script>

<div class="text-center">
    <h1 class="display-5">@ViewBag.Title</h1>
    <p>Generación de @ViewBag.Modulo.</p>
</div>

<form method="post" asp-controller="@ViewBag.Modulo" asp-action="IngresosMensualesFormAdd">
    <div class="form-group">
        <table class="table table-primary">
            <tr>
                <td>
                    <div class="form-group">
                        <span class="form-label">Identificador:</span>
                        <input id="Id" name="Id" class="form-control" type="number" value="@prestamoDetalle.Id" required />
                    </div>
                </td>
                <td>
                    <div class="form-group">
                        <span class="form-label">Cuota:</span>
                        <input id="Cuota" name="Cuota" class="form-control" type="text" min="0.00" max="1000000.00" step="0.01" value="@prestamoDetalle.Cuota" onchange="CalcularMonto()" required />
                    </div>
                </td>
                <td>
                    <div class="form-group">
                        <span class="form-label">Monto Cuota:</span>
                        <input id="MontoCuotaPromedio" name="MontoCuotaPromedio" class="form-control" type="text" min="0.00" max="1000000.00" step="0.01" value="@prestamoDetalle.MontoCuota" required />
                    </div>
                </td>
                <td>
                    <div class="form-group">
                        <span class="form-label">Fecha Depósito/Acreditamiento:</span>
                        <input id="FechaDeposito" name="FechaDeposito" class="form-control" type="date" data-language='es' value="@prestamoDetalle.FechaPagado?.ToString("yyyy-MM-dd")" required>
                    </div>
                </td>
            </tr>
            <tr>
                <td>
                    <div class="form-group">
                        <span class="form-label">Método Pago:</span>
                        <input id="MetodoPago" name="MetodoPago" class="form-control" type="text" value="@prestamoDetalle.MetodoPago" required />
                    </div>
                </td>
                <td>
                    <div class="form-group">
                        <span class="form-label">Comprobante de Pago:</span>
                        <input id="ComprobantePago" name="ComprobantePago" class="form-control" type="text" value="@prestamoDetalle.ComprobantePago" required />
                    </div>
                </td>
                <td align="center">
                    <div class="form-group">
                        <span class="form-label">Observaciones:</span>
                        <input id="Observaciones" name="Observaciones" class="form-control" type="text" value="@prestamoDetalle.Observaciones" required />
                    </div>
                </td>
                <td>
                    <div class="form-group">
                        <span class="form-label">Estado:</span>
                        <select id="Estado" name="Estado" class="form-control" required>
                            @foreach (var item in @lstEstados)
                            {
                                if (item.Selected)
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                    </div>
                </td>
                <td>
                    <div class="form-group">
                        <span class="form-label">PrestamoId:</span>
                        <input id="PrestamoId" name="PrestamoId" class="form-control" type="number" value="@prestamoDetalle.PrestamoId" required />
                    </div>
                </td>
            </tr>
        </table>
    </div>
    <button type="submit" class="btn btn-primary" asp-controller="@ViewBag.Modulo" asp-action="@ViewBag.Modulo" name="action" value="actualizarDetail">Generar</button>
</form>

<p></p>

<a href="/@ViewBag.Modulo" class="btn btn-secondary">Volver</a>
