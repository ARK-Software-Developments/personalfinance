@using PersonalFinance.Helper
@using PersonalFinance.Models.Entidades
@using PersonalFinance.Models.Gastos
@using System.Globalization
@using PersonalFinance.Models.IngresosTipo
@using PersonalFinanceApiNetCoreModel
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@


@{
    CultureInfo culturaArgentina = new CultureInfo("es-AR");

    List<Entidad> entidades = ViewBag.Entidades;
  
    var lstEntidades = new List<SelectListItem>();
    foreach (var e in entidades)
    {
        lstEntidades.Add(
        new SelectListItem()
        {
            Value = e.Id.ToString(),
            Text = e.Nombre,
            Selected = false,
        });
    }

    var lstEstados = ViewBag.Estados;


}

<link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
<link rel="stylesheet" href="~/css/personalfinance.styles.css">

<script>
    function CalcularMonto() {
                console.log($('#Cuotas :selected').val());

                var cuotas = parseFloat($('#Cuotas').val());
                var MontoCuotaPromedio = parseFloat($('#MontoCuotaPromedio').val());
                var montoTotal = MontoCuotaPromedio * cuotas;

                $('#MontoTotal').val(montoTotal);
            };

</script>

<div class="text-center">
    <h1 class="display-5">@ViewBag.Title</h1>
    <p>Generación de @ViewBag.Modulo.</p>
</div>

<form method="post" asp-controller="@ViewBag.Modulo" asp-action="IngresosMensualesFormAdd">
    <div class="form-group">
        <table class="table table-primary">
            <tr>
                <td align="center">
                    <div class="form-group">
                        <span class="form-label">Número:</span>
                        <input id="Numero" name="Numero" class="form-control" type="text" value="" required/>
                    </div>
                </td>
                <td align="center">
                    <div class="form-group">
                        <span class="form-label">Beneficiario:</span>
                        <input id="Beneficiario" name="Beneficiario" class="form-control" type="text" value="" required />
                    </div>
                </td>
                <td>
                    <div class="form-group">
                        <span class="form-label">Fecha Depósito/Acreditamiento:</span>
                        <input id="FechaDeposito" name="FechaDeposito" class="form-control" type="date" data-language='es' value="" required>
                    </div>
                </td>
                <td align="center">
                    <div class="form-group">
                        <span class="form-label">Código Transacción:</span>
                        <input id="CodigoTransaccion" name="CodigoTransaccion" class="form-control" type="text" value="" required />
                    </div>
                </td>
                <td>
                    <div class="form-group">
                        <span class="form-label">Entidad:</span>
                        <select id="Entidad" name="Entidad" class="form-control" required>
                            @foreach (var item in @lstEntidades)
                            {
                                if (item.Selected)
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                    </div>
                </td>
                <td align="center">
                    <div class="form-group">
                        <span class="form-label">Razón:</span>
                        <input id="Razon" name="Razon" class="form-control" type="text" value="" required />
                    </div>
                </td>
                <td align="center">
                    <div class="form-group">
                        <span class="form-label">Resumen:</span>
                        <input id="Resumen" name="Resumen" class="form-control" type="text" value="" required />
                    </div>
                </td>
            </tr>
            <tr>
                <td>
                    <div class="form-group">
                        <span class="form-label">Monto Capital:</span>
                        <input id="MontoCapital" name="MontoCapital" class="form-control" type="text" min="0.00" max="1000000.00" step="0.01" value="0" required />
                    </div>
                </td>
                 <td>
                    <div class="form-group">
                        <span class="form-label">Monto Cta Promedio:</span>
                        <input id="MontoCuotaPromedio" name="MontoCuotaPromedio" class="form-control" type="text" min="0.00" max="1000000.00" step="0.01" value="0" required />
                    </div>
                </td>
                <td>
                    <div class="form-group">
                        <span class="form-label">Cuotas:</span>
                        <input id="Cuotas" name="Cuotas" class="form-control" type="text" min="0.00" max="1000000.00" step="0.01" value="0" onchange="CalcularMonto()" required />
                    </div>
                </td>
                <td>
                    <div class="form-group">
                        <span class="form-label">Monto Total:</span>
                        <input id="MontoTotal" name="MontoTotal" class="form-control" type="text" min="0.00" max="1000000.00" step="0.01" value="0" required />
                    </div>
                </td>
                
                <td>
                    <div class="form-group">
                        <span class="form-label">Estado:</span>
                        <select id="Estado" name="Estado" class="form-control" required>
                            @foreach (var item in @lstEstados)
                            {
                                if (item.Selected)
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                    </div>
                </td>
            </tr>
        </table>
    </div>
    <button type="submit" class="btn btn-primary" asp-controller="@ViewBag.Modulo" asp-action="@ViewBag.Modulo" name="action" value="generar">Generar</button>
</form>

<p></p>

<a href="/@ViewBag.Modulo" class="btn btn-secondary">Volver</a>
