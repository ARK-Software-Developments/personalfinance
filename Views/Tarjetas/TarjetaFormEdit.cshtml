@using PersonalFinanceApiNetCoreModel;
@using PersonalFinance.Models.TarjetaConsumos
@using PersonalFinance.Models.Tarjetas
@using System.Globalization
@using System.Text.Json
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@

@{

    Tarjeta tarjeta = ViewBag.Tarjeta;
    List<Entidad> entidades = ViewBag.Entidades;
    List<TarjetaConsumoResumen> tarjetaConsumoResumen = ViewBag.TarjetaResumen;

    var labelsArray = (string[])ViewBag.Labels; // Convertir a array
    var labels = string.Join(",", labelsArray.Select(l => $"'{l}'"));

    string modeView = ViewBag.ModeView ? "disabled" : "";
    var listaEntidades = new List<SelectListItem>();
    foreach (var e in entidades)
    {
        listaEntidades.Add(
        new SelectListItem()
                {
                    Value = e.Id.ToString(),
                    Text = e.Nombre,
                    Selected = (tarjeta.Entidad.Id == e.Id ? true : false)
                });
    }


    decimal ene = 0;
    decimal feb = 0;
    decimal mar = 0;
    decimal abr = 0;
    decimal may = 0;
    decimal jun = 0;
    decimal jul = 0;
    decimal ago = 0;
    decimal set = 0;
    decimal oct = 0;
    decimal nov = 0;
    decimal dic = 0;

    var valoresArray = (int[])ViewBag.ResumenTotales.ToArray(); // Convertir a array
    var strResumenTotales = string.Join(",", valoresArray);
    var label = $"Resumen {@tarjeta.Nombre}";
}
<link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
<link rel="stylesheet" href="~/css/personalfinance.styles.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    function CambioEntidad() {
                console.log("CambioEntidad");
                console.log($('#Entidad :selected').val());

                $('#EntidadSel').val($('#Entidad :selected').val());
            };

</script>

<div class="text-center">
    <h1 class="display-5">@ViewBag.Title</h1>
    <p>Actualización de @ViewBag.Modulo.</p>
</div>

<a href="/@ViewBag.Modulo/TarjetasCredito" class="btn btn-secondary">Volver</a>
<p></p>
<p></p>
<div class="tab-content">
    <form method="post" asp-controller="@ViewBag.Modulo" asp-action="TarjetaFormEdit">
        <div class="form-group">
            <table class="table table-primary">
                <tr>
                    <td>
                        <div class="form-group">
                            <span class="form-label">Identificador Interno:</span>
                            <input type="text" id="Id" name="Id" class="form-control" value="@tarjeta.Id" readonly />
                        </div>
                    </td>
                    <td>
                        <div class="form-group">
                            <span class="form-label">Nombre:</span>
                            <input type="text" id="Nombre" name="Nombre" class="form-control" value="@tarjeta.Nombre" required @modeView />
                        </div>
                    </td>
                    <td>
                        <div class="form-group">
                            <span class="form-label">Entidad:</span>
                            <select id="Entidad" name="Entidad" class="form-control" onchange="CambioEntidad()" required @modeView>
                                @foreach (var item in @listaEntidades)
                                {
                                    if (item.Selected)
                                    {
                                        <option value="@item.Value" selected>@item.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                            <span class="select-arrow"></span>
                            <input id="EntidadSel" name="EntidadSel" class="form-control" value="@tarjeta.Entidad.Id" hidden>
                        </div>
                    </td>
                    <td>
                        <div class="form-group">
                            <span class="form-label">Fecha Cierre:</span>
                            <input id="FechaCierre" name="FechaCierre" class="form-control" type="date" data-language='es' value="@tarjeta.FechaCierre.ToString("yyyy-MM-dd")" required @modeView>
                        </div>
                    </td>
                    <td>
                        <div class="form-group">
                            <span class="form-label">Fecha Vencimiento:</span>
                            <input id="FechaVencimiento" name="FechaVencimiento" class="form-control" type="date" data-language='es' value="@tarjeta.FechaVencimiento.ToString("yyyy-MM-dd")" required @modeView>
                        </div>
                    </td>
                </tr>     
            </table>
            <p></p>
            <button type="submit" class="btn btn-primary" asp-controller="@ViewBag.Modulo" asp-action="TarjetasCredito" name="action" value="actualizar">Actualizar</button>
            <p></p>
            <div class="row">
                <!-- -->
                <canvas id="miGrafico" style="height: 500px; border: 2px;"></canvas>
                <script>
                    const ctx = document.getElementById('miGrafico').getContext('2d');
                    const miGrafico = new Chart(ctx, {
                        type: 'line', // Puedes usar 'bar' 'line', 'pie', etc.
                        data: {
                            labels: [@Html.Raw(labels)],
                            datasets: [{
                                label: @Html.Raw(JsonSerializer.Serialize(@label)),
                                data: [@Html.Raw(strResumenTotales)],
                                backgroundColor: '#1abc9c',
                                borderColor: 'rgba(54, 162, 235, 1)',
                                borderWidth: 1
                            }]
                        },
                        options: {
                            responsive: true,
                            scales: {
                                y: {
                                    beginAtZero: true
                                }
                            }
                        }
                    });
                </script>
                <!-- -->
            </div>
            <table class="table table-secondary">
                <thead>
                    <tr>
                        <th scope="col">Entidad de Compra</th>
                        <th scope="col" align="right">Enero</th>
                        <th scope="col" align="right">Febrero</th>
                        <th scope="col" align="right">Marzo</th>
                        <th scope="col" align="right">Abril</th>
                        <th scope="col" align="right">Mayo</th>
                        <th scope="col" align="right">Junio</th>
                        <th scope="col" align="right">Julio</th>
                        <th scope="col" align="right">Agosto</th>
                        <th scope="col" align="right">Septiembre</th>
                        <th scope="col" align="right">Octubre</th>
                        <th scope="col" align="right">Noviembre</th>
                        <th scope="col" align="right">Diciembre</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var detalle in @tarjetaConsumoResumen)
                    {
                        <tr>
                            <td scope="row" title="@detalle.NombreReferencia">@detalle.EntidadCompra</td>
                            <td scope="row" align="right">@detalle.Enero.ToString("C", new CultureInfo("es-AR"))</td>
                            <td scope="row" align="right">@detalle.Febrero.ToString("C", new CultureInfo("es-AR"))</td>
                            <td scope="row" align="right">@detalle.Marzo.ToString("C", new CultureInfo("es-AR"))</td>
                            <td scope="row" align="right">@detalle.Abril.ToString("C", new CultureInfo("es-AR"))</td>
                            <td scope="row" align="right">@detalle.Mayo.ToString("C", new CultureInfo("es-AR"))</td>
                            <td scope="row" align="right">@detalle.Junio.ToString("C", new CultureInfo("es-AR"))</td>
                            <td scope="row" align="right">@detalle.Julio.ToString("C", new CultureInfo("es-AR"))</td>
                            <td scope="row" align="right">@detalle.Agosto.ToString("C", new CultureInfo("es-AR"))</td>
                            <td scope="row" align="right">@detalle.Septiembre.ToString("C", new CultureInfo("es-AR"))</td>
                            <td scope="row" align="right">@detalle.Octubre.ToString("C", new CultureInfo("es-AR"))</td>
                            <td scope="row" align="right">@detalle.Noviembre.ToString("C", new CultureInfo("es-AR"))</td>
                            <td scope="row" align="right">@detalle.Diciembre.ToString("C", new CultureInfo("es-AR"))</td>
                        </tr>
                    }
                    <tr style="font-weight: bold; background-color: #90b3ff">
                        <td scope="row">Total:</td>
                        <td scope="row" align="right">@valoresArray[0].ToString("C", new CultureInfo("es-AR"))</td>
                        <td scope="row" align="right">@valoresArray[1].ToString("C", new CultureInfo("es-AR"))</td>
                        <td scope="row" align="right">@valoresArray[2].ToString("C", new CultureInfo("es-AR"))</td>
                        <td scope="row" align="right">@valoresArray[3].ToString("C", new CultureInfo("es-AR"))</td>
                        <td scope="row" align="right">@valoresArray[4].ToString("C", new CultureInfo("es-AR"))</td>
                        <td scope="row" align="right">@valoresArray[5].ToString("C", new CultureInfo("es-AR"))</td>
                        <td scope="row" align="right">@valoresArray[6].ToString("C", new CultureInfo("es-AR"))</td>
                        <td scope="row" align="right">@valoresArray[7].ToString("C", new CultureInfo("es-AR"))</td>
                        <td scope="row" align="right">@valoresArray[8].ToString("C", new CultureInfo("es-AR"))</td>
                        <td scope="row" align="right">@valoresArray[9].ToString("C", new CultureInfo("es-AR"))</td>
                        <td scope="row" align="right">@valoresArray[10].ToString("C", new CultureInfo("es-AR"))</td>
                        <td scope="row" align="right">@valoresArray[11].ToString("C", new CultureInfo("es-AR"))</td>
                    </tr>
                </tbody>

            </table>
        </div>        
    </form>
</div>
<p></p>
